# Slack App Credentials
# Get these from https://api.slack.com/apps → Your App → Basic Information
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# OAuth Redirect URI
# Must match exactly what's configured in Slack app settings
SLACK_REDIRECT_URI=http://localhost:3001/slack/callback

# Internal API Key (agent uses this to query workspaces)
# Generate a strong random string: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-strong-random-key

# Success redirect after install
SUCCESS_REDIRECT_URL=https://po-agent-landing.vercel.app/success

# Database path
DB_PATH=./luna-oauth.db

# Server port
PORT=3001
